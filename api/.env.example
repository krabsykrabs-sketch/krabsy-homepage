# Copy to Coolify environment variables; do NOT commit a real .env file.

# Basic-auth credentials for /dashboard/ and /dashboard/raw.
DASHBOARD_USERNAME=jan
DASHBOARD_PASSWORD=changeme_set_in_coolify

# MaxMind GeoLite2-Country.mmdb path inside the container (mounted volume).
# If the file does not exist, the service logs a warning and records
# country="unknown" for every event. Setting this up is optional.
GEOIP_DB_PATH=/data/GeoLite2-Country.mmdb
